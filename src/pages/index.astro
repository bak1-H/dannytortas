---
// Self-hosted fonts (bundled, served from our own origin — no render-blocking Google Fonts)
import '@fontsource-variable/plus-jakarta-sans';
import '@fontsource/libre-caslon-text/400.css';
import '@fontsource/libre-caslon-text/700.css';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import AboutUs from '../components/AboutUs.astro';
import Specialties from '../components/Specialties.astro';
import Gallery from '../components/Gallery.astro';
import Variety from '../components/Variety.astro';
import HowToOrder from '../components/HowToOrder.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { getImage } from 'astro:assets';
import heroImage from '../img/img_tortas.png';

// Same params as Hero.astro so the generated URL matches — lets us preload the LCP image
const heroBg = await getImage({ src: heroImage, format: 'webp', width: 1920, quality: 68 });

// --- SEO constants (single source of truth) ---
const SITE_URL = 'https://dannytortas.cl';
const TITLE = 'Danny Tortas | Tortas y Coctelería a Pedido en Santiago';
const DESCRIPTION =
  'Tortas personalizadas, cupcakes y coctelería dulce y salada a pedido para cumpleaños y eventos en Santiago. Decoración artesanal, ingredientes frescos y entregas coordinadas.';
const OG_IMAGE = `${SITE_URL}/og-image.png`;
const PHONE = '+56961497814';
const INSTAGRAM = 'https://www.instagram.com/danny_tortas/';

// --- Structured data: local bakery business ---
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Bakery',
  name: 'Danny Tortas',
  description: DESCRIPTION,
  image: OG_IMAGE,
  url: `${SITE_URL}/`,
  telephone: PHONE,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Santiago',
    addressCountry: 'CL'
  },
  areaServed: 'Santiago, Chile',
  sameAs: [INSTAGRAM],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '19:00'
    },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday', opens: '08:00', closes: '17:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '08:00', closes: '14:00' }
  ]
};
---

<html lang="es" class="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preload the hero background — it's the LCP, and as a CSS background it would
         otherwise be discovered late. fetchpriority high pulls it into the critical path. -->
    <link rel="preload" as="image" href={heroBg.src} fetchpriority="high" />

    <!-- Primary meta -->
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={`${SITE_URL}/`} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#9282C4" />

    <!-- Icons -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Danny Tortas" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:url" content={`${SITE_URL}/`} />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Danny Tortas — tortas y coctelería a pedido en Santiago" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Text fonts are self-hosted (imported in the frontmatter). Only the Material
         Symbols icon font stays remote, loaded non-blocking so it never delays render. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      />
    </noscript>
  </head>

  <body class="bg-background-light font-body text-ink antialiased">
    <Navbar />
    <main>
      <Hero />
      <AboutUs />
      <Specialties />
      <Gallery />
      <Variety />
      <HowToOrder />
      <Contact />
    </main>
    <Footer />
    <script type="module" src="/scripts/animations.js"></script>
  </body>
</html>
