---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SectionTitle from './ui/SectionTitle.astro';

// One glob per folder (globs must be static literals). Note: tartas + new folders use .jpg
const coctMods = import.meta.glob<{ default: ImageMetadata }>('../img/Cocteleria/*.jpeg', { eager: true });
const persMods = import.meta.glob<{ default: ImageMetadata }>('../img/personalizadas/*.jpeg', { eager: true });
const tartMods = import.meta.glob<{ default: ImageMetadata }>('../img/tartas/*.jpg', { eager: true });
const infaMods = import.meta.glob<{ default: ImageMetadata }>('../img/Infantiles/*.jpg', { eager: true });
const matrMods = import.meta.glob<{ default: ImageMetadata }>('../img/matrimonios/*.jpg', { eager: true });
const sinaMods = import.meta.glob<{ default: ImageMetadata }>('../img/sin-azucar/*.jpg', { eager: true });

const toPhotos = (mods: Record<string, { default: ImageMetadata }>) =>
  Object.entries(mods)
    .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
    .map(([, mod]) => mod.default);

const categories = [
  { id: 'tartas', label: 'Tartas', photos: toPhotos(tartMods) },
  { id: 'personalizadas', label: 'Tortas Personalizadas', photos: toPhotos(persMods) },
  { id: 'infantiles', label: 'Tortas Infantiles', photos: toPhotos(infaMods) },
  { id: 'matrimonios', label: 'Matrimonios', photos: toPhotos(matrMods) },
  { id: 'sin-azucar', label: 'Sin Azúcar', photos: toPhotos(sinaMods) },
  { id: 'cocteleria', label: 'Coctelería', photos: toPhotos(coctMods) }
];

// PLACEHOLDER — reemplazá por los ingredientes reales. Se muestra al pasar el mouse o tocar una card.
const info: Record<string, string> = {
  tartas: 'Masa quebrada artesanal, relleno cremoso y fruta o cobertura de estación.',
  personalizadas: 'Bizcocho esponjoso, rellenos a elección y decoración a medida para tu evento.',
  infantiles: 'Diseños temáticos coloridos, bizcocho suave y rellenos pensados para los más chicos.',
  matrimonios: 'Tortas de varios pisos, terminaciones elegantes y sabores a medida para tu gran día.',
  'sin-azucar': 'Endulzadas de forma natural, ideales para diabéticos o quienes cuidan el azúcar.',
  cocteleria: 'Bocados dulces y salados, preparados al momento con ingredientes frescos.'
};
---

<section id="galeria" data-section class="py-section bg-cream overflow-hidden">
  <div class="max-w-container mx-auto px-6">
    <SectionTitle eyebrow="Galería" title="Nuestras creaciones" align="left" />

    <div role="tablist" aria-label="Categorías" class="flex flex-wrap gap-3 mt-8 mb-8">
      {
        categories.map((cat, i) => (
          <button
            type="button"
            role="tab"
            data-tab={cat.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            class="rounded-full border border-primary/20 bg-white px-5 py-2 text-sm font-semibold text-ink transition-colors hover:text-primary aria-selected:border-primary aria-selected:bg-primary aria-selected:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            {cat.label}
          </button>
        ))
      }
    </div>
  </div>

  {
    categories.map((cat, i) => (
      <div data-panel={cat.id} class={i === 0 ? '' : 'hidden'}>
        <div class="marquee">
          <div class="marquee-track">
            {cat.photos.map((photo, j) => (
              <figure class="mr-5 shrink-0 w-[240px] sm:w-[280px] cursor-pointer select-none">
                <div class="clip-fix relative aspect-[3/4] overflow-hidden rounded-3xl shadow-soft">
                  <Image
                    src={photo}
                    alt={`${cat.label} de Danny Tortas ${j + 1}`}
                    width={560}
                    format="webp"
                    loading="lazy"
                    class="h-full w-full object-cover"
                  />
                  <div class="card-info absolute inset-x-0 bottom-0 p-5 pt-12">
                    <p class="text-white text-sm leading-snug font-medium">{info[cat.id]}</p>
                  </div>
                </div>
              </figure>
            ))}
          </div>
        </div>
      </div>
    ))
  }
</section>

<script>
  const section = document.getElementById('galeria');
  if (section) {
    const tabs = [...section.querySelectorAll<HTMLElement>('[data-tab]')];
    const panels = [...section.querySelectorAll<HTMLElement>('[data-panel]')];

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.getAttribute('data-tab');
        tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
        panels.forEach((p) => p.classList.toggle('hidden', p.getAttribute('data-panel') !== id));
      });
    });

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouch = window.matchMedia('(hover: none)').matches;
    const AUTO_SPEED = 0.35; // px per frame — gentle ambient drift
    const RESUME_DELAY = 1800; // ms to wait after the user interacts before drifting again

    section.querySelectorAll<HTMLElement>('.marquee').forEach((marquee) => {
      const track = marquee.querySelector<HTMLElement>('.marquee-track');
      if (!track) return;

      // The markup renders ONE set of photos. We clone whole sets until the
      // track is comfortably wider than the viewport, then run a "treadmill":
      // the scroll position is kept inside the [unit, 2*unit) band and wrapped
      // by one set width, so the loop is infinite and never hits an edge —
      // regardless of how few photos a category has or how wide the screen is.
      const originals = [...track.children] as HTMLElement[];
      if (!originals.length) return;

      let unit = 0; // width of a single set; 0 means "needs (re)build"

      const buildClones = () => {
        track.querySelectorAll('[data-clone]').forEach((n) => n.remove());
        unit = track.scrollWidth; // only the original set is present now
        if (unit <= 0) return; // panel still hidden (display:none) — try again later
        const target = Math.max(unit * 3, marquee.clientWidth + unit * 2) + unit;
        while (track.scrollWidth < target) {
          for (const node of originals) {
            const clone = node.cloneNode(true) as HTMLElement;
            clone.setAttribute('data-clone', '');
            clone.setAttribute('aria-hidden', 'true');
            track.appendChild(clone);
          }
        }
        marquee.scrollLeft = unit;
        pos = unit;
      };

      let pos = 0;
      let hovering = false;
      let dragging = false;
      let activeCard = false;
      let resumeAt = 0;
      let wasAuto = false;

      const pause = () => { resumeAt = performance.now() + RESUME_DELAY; };

      // Keep the scroll position inside the central band [unit, 2*unit)
      const wrap = () => {
        if (unit <= 0) return;
        if (marquee.scrollLeft >= unit * 2) marquee.scrollLeft -= unit;
        else if (marquee.scrollLeft < unit) marquee.scrollLeft += unit;
      };

      const tick = () => {
        const visible = marquee.offsetParent !== null;
        if (visible && unit === 0) buildClones(); // lazy build once the panel is shown
        const canAuto =
          visible && unit > 0 && !reduceMotion && !hovering && !dragging && !activeCard && performance.now() >= resumeAt;
        if (canAuto) {
          if (!wasAuto) pos = marquee.scrollLeft; // resync after the user moved it
          pos += AUTO_SPEED;
          if (pos >= unit * 2) pos -= unit;
          marquee.scrollLeft = pos;
        }
        wasAuto = canAuto;
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);

      // Rebuild when layout changes (viewport width / responsive card sizes).
      let resizeTimer = 0;
      window.addEventListener('resize', () => {
        window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => { unit = 0; }, 200);
      });
      window.addEventListener('load', () => { unit = 0; });

      // Keep the loop seamless for native (touch momentum, trackpad) scrolling.
      // This must NOT pause the drift — programmatic scroll fires here too.
      marquee.addEventListener('scroll', wrap, { passive: true });

      // Only real user input pauses the drift
      marquee.addEventListener('wheel', pause, { passive: true });
      marquee.addEventListener('touchstart', pause, { passive: true });
      marquee.addEventListener('touchmove', pause, { passive: true });
      marquee.addEventListener('pointerenter', (e) => { if (e.pointerType === 'mouse') hovering = true; });
      marquee.addEventListener('pointerleave', (e) => { if (e.pointerType === 'mouse') hovering = false; });

      // Mouse click-and-drag to scroll (touch already scrolls natively)
      let startX = 0;
      let startScroll = 0;
      let moved = false;
      marquee.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse') return;
        dragging = true;
        moved = false;
        startX = e.clientX;
        startScroll = marquee.scrollLeft;
        marquee.classList.add('is-dragging');
        marquee.setPointerCapture(e.pointerId);
      });
      marquee.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        marquee.scrollLeft = startScroll - dx;
        // Wrap mid-drag, shifting the anchor so the photos keep tracking the cursor
        if (unit > 0) {
          if (marquee.scrollLeft >= unit * 2) { marquee.scrollLeft -= unit; startScroll -= unit; }
          else if (marquee.scrollLeft < unit) { marquee.scrollLeft += unit; startScroll += unit; }
        }
      });
      const stopDrag = (e: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        marquee.classList.remove('is-dragging');
        pause();
        try { marquee.releasePointerCapture(e.pointerId); } catch {}
      };
      marquee.addEventListener('pointerup', stopDrag);
      marquee.addEventListener('pointercancel', stopDrag);
      // Swallow the click that fires at the end of a real drag so it can't toggle a card
      marquee.addEventListener('click', (e) => {
        if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; }
      }, true);
      marquee.addEventListener('dragstart', (e) => e.preventDefault());

      // Touch: tap a card to reveal its info and hold the drift.
      // Delegated so cloned cards work too.
      if (isTouch) {
        marquee.addEventListener('click', (e) => {
          const fig = (e.target as HTMLElement).closest('figure');
          if (!fig || !marquee.contains(fig)) return;
          const wasActive = fig.classList.contains('is-active');
          marquee.querySelectorAll('figure.is-active').forEach((el) => el.classList.remove('is-active'));
          activeCard = !wasActive;
          if (!wasActive) fig.classList.add('is-active');
        });
      }
    });
  }
</script>
