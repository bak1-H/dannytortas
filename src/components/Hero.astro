---
import { getImage } from 'astro:assets';
import tortasImage from '../img/img_tortas.png';
import Button from './ui/Button.astro';

const WHATSAPP = 'https://wa.me/56961497814';

// Optimized hero background (webp, resized) instead of the raw 2 MB PNG
const heroBg = await getImage({ src: tortasImage, format: 'webp', width: 1920, quality: 68 });
---

<section
  id="top"
  data-section
  class="relative flex min-h-[680px] h-screen items-center justify-center overflow-hidden"
  aria-label="Tortas artesanales de Danny Tortas"
>
  <div class="hero-bg absolute inset-0" style={`background-image: url(${heroBg.src});`} aria-hidden="true"></div>
  <div class="hero-gradient absolute inset-0" aria-hidden="true"></div>

  <div class="reveal relative z-10 mx-auto max-w-4xl px-6 text-center">
    <h1 class="font-display text-4xl sm:text-6xl text-white leading-[1.1] drop-shadow-lg mb-6">
      Sabores artesanales que enamoran
    </h1>
    <p class="mx-auto max-w-2xl text-lg text-white/90 leading-relaxed mb-10">
      Tortas, masas y coctelería dulce y salada, hechas a mano con amor para tus momentos especiales.
      Más de 15 años endulzando celebraciones.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="#specialties" variant="outline" class="px-10 py-4 text-base">Ver Especialidades</Button>
      <Button href={WHATSAPP} external variant="outline" class="px-10 py-4 text-base">Contáctanos</Button>
    </div>
  </div>

  <a
    href="#story"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/70 hover:text-white transition-colors animate-bounce"
    aria-label="Bajar a la siguiente sección"
  >
    <span class="material-symbols-outlined text-4xl">expand_more</span>
  </a>
</section>
