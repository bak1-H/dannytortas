---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'center' | 'left';
  tone?: 'default' | 'light';
}

const { eyebrow, title, align = 'center', tone = 'default' } = Astro.props;

const isCenter = align === 'center';
const isLight = tone === 'light';

const wrapper = `reveal max-w-2xl ${isCenter ? 'text-center mx-auto' : ''}`;
const titleColor = isLight ? 'text-white' : 'text-primary';
const eyebrowCls = isLight
  ? 'bg-white/15 text-white'
  : 'bg-sky text-primary';
---

<div class={wrapper}>
  {
    eyebrow && (
      <span
        class={`inline-block px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-5 ${eyebrowCls}`}
      >
        {eyebrow}
      </span>
    )
  }
  <h2 class={`font-display text-4xl md:text-5xl leading-tight ${titleColor}`}>{title}</h2>
  {
    isCenter && (
      <div class="w-24 h-1 bg-gradient-to-r from-primary to-turquoise rounded-full mx-auto mt-6" />
    )
  }
</div>
