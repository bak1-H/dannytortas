---
import Button from './ui/Button.astro';

const WHATSAPP = 'https://wa.me/56961497814';

const steps = [
  { n: 1, title: 'Elige', text: 'Mira nuestras especialidades y encuentra lo ideal para tu evento.' },
  { n: 2, title: 'Personaliza', text: 'Escoge rellenos, bases y decoración a tu gusto.' },
  { n: 3, title: 'Ordena', text: 'Confirmas los detalles por WhatsApp y nosotros nos encargamos del resto.' }
];
---

<section id="order" data-section class="py-section px-6 bg-cream">
  <div class="max-w-container mx-auto flex flex-col md:flex-row gap-16 items-center">
    <div class="reveal reveal-left w-full md:w-1/3">
      <h2 class="font-display text-4xl text-primary mb-6">¿Cómo pedir?</h2>
      <p class="text-lg text-muted leading-relaxed mb-8">
        Hacer tu pedido es simple y rápido. Sigue estos pasos y coordinamos la entrega.
      </p>
      <Button href={WHATSAPP} external variant="turquoise" class="gap-3">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;"></span>
        Pregunta sin Compromiso🫶
      </Button>
    </div>

    <div data-stagger class="w-full md:w-2/3 grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        steps.map((step) => (
          <div class="reveal relative rounded-3xl border border-primary/10 bg-white p-8 shadow-soft">
            <span class="absolute -top-4 -left-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary text-xl font-bold text-white">
              {step.n}
            </span>
            <h3 class="font-display text-xl text-primary mt-2 mb-3">{step.title}</h3>
            <p class="text-muted leading-relaxed">{step.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
