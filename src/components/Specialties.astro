---
import image1 from '../img/1.png';
import image2 from '../img/2.png';
import image3 from '../img/3.png';
import SectionTitle from './ui/SectionTitle.astro';
import ProductCard from './ui/ProductCard.astro';

const WHATSAPP = 'https://wa.me/56961497814';

const products = [
  {
    image: image1.src,
    title: 'Brazo de Reina',
    text: 'Bizcocho enrollado con relleno cremoso y cobertura de frutos secos para un final crujiente.',
    badge: 'Favorito',
    cta: 'Personalizar'
  },
  {
    image: image2.src,
    title: 'Tortas Personalizadas',
    text: 'Diseños únicos para tu celebración: bizcocho húmedo, ganache, drip de cacao y topping a mano.',
    badge: 'Más pedida',
    cta: 'Cotizar'
  },
  {
    image: image3.src,
    title: 'Coctelería Surtida',
    text: 'Mesa con variedad de bocados dulces y salados, perfectos para eventos y celebraciones.',
    badge: 'Cocteles',
    cta: 'Ver variedad'
  }
];
---

<section id="specialties" data-section class="py-section px-6 bg-sky/40">
  <div class="max-w-container mx-auto mb-16">
    <SectionTitle eyebrow="Especialidades" title="Nuestras especialidades" />
  </div>

  <div data-stagger class="max-w-container mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    {products.map((product) => <ProductCard {...product} href={WHATSAPP} />)}
  </div>
</section>
