---
import Button from './ui/Button.astro';

const WHATSAPP = 'https://wa.me/56961497814';
const INSTAGRAM = 'https://www.instagram.com/danny_tortas/';
---

<section id="contact" data-section class="px-6 pb-section">
  <div
    class="reveal max-w-container mx-auto relative overflow-hidden rounded-[3rem] bg-sky/60 p-12 md:p-24 text-center"
  >
    <span
      class="material-symbols-outlined pointer-events-none absolute -bottom-8 -left-8 text-[220px] text-primary/10 select-none"
      aria-hidden="true"
    >celebration</span>

    <div class="relative z-10">
      <h2 class="font-display text-4xl md:text-5xl text-primary mb-6">¿Tienes un evento pronto?</h2>
      <p class="mx-auto max-w-xl text-lg text-muted leading-relaxed mb-10">
        Escríbenos directamente por WhatsApp para recibir una asesoría personalizada, o mira nuestras
        creaciones en Instagram.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={WHATSAPP} external class="px-10 py-4 text-base">
          <span class="material-symbols-outlined" aria-hidden="true">chat</span>
          Escribir por WhatsApp
        </Button>
        <Button href={INSTAGRAM} external variant="turquoise" class="px-10 py-4 text-base">
          <span class="material-symbols-outlined" aria-hidden="true">photo_camera</span>
          Ver Instagram
        </Button>
      </div>
    </div>
  </div>
</section>
