---
import { Image } from 'astro:assets';
import aboutImage from '../img/img_brazo.png';
import SectionTitle from './ui/SectionTitle.astro';

const highlights = [
  { icon: 'restaurant', label: 'Ingredientes frescos' },
  { icon: 'favorite', label: 'Hecho a mano' },
  { icon: 'history', label: 'Recetas caseras' },
  { icon: 'cake', label: 'Horneado al día' }
];
---

<section id="story" data-section class="py-section px-6 bg-cream">
  <div class="max-w-container mx-auto grid md:grid-cols-2 items-center gap-16">
    <div class="reveal reveal-left order-2 md:order-1">
      <SectionTitle eyebrow="Nuestra Historia" title="Artesanía en cada detalle" align="left" />
      <p class="mt-6 text-lg text-muted leading-relaxed">
        Somos una PYME dedicada a tortas, masas y coctelería dulce y salada, con una amplia variedad de
        rellenos y bases para cada creación. Nacimos en la cocina de casa y hoy seguimos con la misma
        obsesión: insumos frescos, mantequilla de verdad y recetas propias.
      </p>

      <div class="mt-10 grid grid-cols-2 gap-6">
        {
          highlights.map((item) => (
            <div class="flex items-center gap-3">
              <span class="flex h-12 w-12 items-center justify-center rounded-full bg-sky text-primary">
                <span class="material-symbols-outlined" aria-hidden="true">{item.icon}</span>
              </span>
              <span class="font-semibold text-ink">{item.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="reveal reveal-right order-1 md:order-2 relative">
      <div class="aspect-square overflow-hidden rounded-2xl shadow-soft">
        <Image src={aboutImage} alt="Torta artesanal de Danny Tortas" width={700} format="webp" class="h-full w-full object-cover" />
      </div>
      <div class="absolute -bottom-6 -left-6 hidden lg:block rounded-2xl bg-primary p-8 shadow-soft max-w-xs">
        <p class="font-display text-xl italic text-white">"Calidad que se siente en cada bocado."</p>
      </div>
    </div>
  </div>
</section>
